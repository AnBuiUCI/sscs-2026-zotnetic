.control
  op
  let b1 = v(bias1)
  let b2 = v(bias2)
  let b3 = v(bias3)
  let b4 = v(bias4)
  echo \\"$&b1 $&b2 $&b3 $&b4\\" >> /foss/designs/sscs-2026-zotnetic/activities/opamp2Enzo/Sim_results/biasTB2_results.txt
.endc"

}
